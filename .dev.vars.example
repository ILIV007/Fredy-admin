# Fredy — Local Development Secrets
# Copy this file to .dev.vars and fill in your values.
# .dev.vars is used by `wrangler dev` for local testing.
# NEVER commit .dev.vars to git!

# === REQUIRED ===
BOT_TOKEN=123456:ABC-DEF_your_bot_token_from_botfather
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com
OPENROUTER_API_KEY=your_openrouter_api_key_from_openrouter_ai

# === RECOMMENDED ===
WEBHOOK_SECRET=your_random_webhook_secret_string
DEBUG_TOKEN=your_random_debug_token_string

# === OPTIONAL (API keys for content sources) ===
NEWSAPI_KEY=your_newsapi_key_from_newsapi_org
NASA_API_KEY=your_nasa_key_from_api_nasa_gov
GITHUB_TOKEN=your_github_personal_access_token
